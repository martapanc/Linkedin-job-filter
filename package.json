{
  "name": "linkedin-job-filter-gemini",
  "displayName": "LinkedIn Job Filter",
  "version": "2.0.0",
  "description": "AI-powered job ad analyzer. Flags misleading remote listings and checks location eligibility.",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package",
    "prepare": "husky"
  },
  "dependencies": {
    "@plasmohq/messaging": "latest",
    "@plasmohq/storage": "latest",
    "plasmo": "latest",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/chrome": "latest",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "husky": "^9.1.7",
    "typescript": "^5"
  },
  "manifest": {
    "permissions": ["storage"],
    "host_permissions": [
      "https://www.linkedin.com/*",
      "https://generativelanguage.googleapis.com/*",
      "http://localhost/*",
      "http://127.0.0.1/*"
    ],
    "web_accessible_resources": [
      {
        "resources": ["assets/prompt.md"],
        "matches": ["https://www.linkedin.com/*"]
      }
    ],
    "action": {
      "default_title": "LinkedIn Job Filter Settings",
      "default_popup": "popup.html"
    }
  }
}
